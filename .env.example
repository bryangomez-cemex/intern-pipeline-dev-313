# ── Azure Communication Services (ACS) Email ─────────────────────────────────
# No Microsoft Graph, no SMTP. These must ALSO be set in the Azure Function App:
#   Portal → Function App → Settings → Environment variables / Application settings.
EMAIL_PROVIDER=azure_communication_services
EMAIL_SIMULATION_MODE=true            # safe default; set false to send real email
ACS_CONNECTION_STRING=
ACS_SENDER_EMAIL=
ACS_SENDER_NAME=Intern Pipeline
TEST_EMAIL_TO=

# ── Notification recipients ──────────────────────────────────────────────────
# RH_RECIPIENT_EMAILS are fixed internal recipients for HR notifications.
# COPARMEX_RECIPIENT_EMAILS currently uses a placeholder until the official
# COPARMEX recipient is provided. Practicantes usually use CEMEX emails, while
# new hires may still use personal emails until their CEMEX account exists.
RH_RECIPIENT_EMAILS=bryan.gomez@ext.cemex.com,valeria.acunaam@cemex.com
COPARMEX_RECIPIENT_EMAILS=bryan.gomez@ext.cemex.com

# ── Azure SQL ────────────────────────────────────────────────────────────────
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_AUTH_MODE=default

# ── Storage / containers ─────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
RAW_UPLOADS_CONTAINER=raw-uploads
ERROR_REPORTS_CONTAINER=error-reports
ARCHIVE_CONTAINER=archive

# ── Document Intelligence (OCR for scanned PDFs/images) ──────────────────────
DOC_INTEL_ENDPOINT=
DOC_INTEL_KEY=

# ── Power BI ─────────────────────────────────────────────────────────────────
POWERBI_DASHBOARD_URL=
